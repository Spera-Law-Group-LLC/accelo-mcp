# Accelo OAuth (Web Application) credentials
ACCELO_CLIENT_ID=
ACCELO_CLIENT_SECRET=

# Accelo deployment endpoints (change 'spera' to your deployment)
ACCELO_BASE_URL=https://spera.api.accelo.com/api/v0
ACCELO_OAUTH_URL=https://spera.api.accelo.com/oauth2/v0

# Public URL where this server is reachable (used for OAuth discovery + redirect)
PUBLIC_BASE_URL=https://accelo-mcp.ai.speralaw.com
OAUTH_REDIRECT_URI=https://accelo-mcp.ai.speralaw.com/oauth/callback

# Accelo scopes to request when a user authorizes
OAUTH_SCOPE=read(all) write(all)

# Local token store + port
TOKEN_DB_PATH=/app/data/tokens.db
PORT=8787
